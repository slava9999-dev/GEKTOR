# Gerald-SuperBrain .gitignore

# Sensitive data
.openclaw/config.json
*.env
.env.*
secrets/

# ChromaDB local data
memory/chroma/
gerald-memory/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs (keep structure, ignore content)
*.log

# Indexer state (generated)
scripts/.index_state.json

# Bridge temp files
bridge/inbox/*.md
bridge/outbox/*.md
!bridge/inbox/.gitkeep
!bridge/outbox/.gitkeep
!bridge/shared-context/.gitkeep
